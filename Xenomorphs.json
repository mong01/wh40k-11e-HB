    "sharedRules": [
      {
        "name": "Acid Blood",
        "id": "0683-9c51-0619-5858",
        "hidden": false,
        "description": "Each time a model with this ability loses a wound as a result of a melee attack, roll one D6: on a 6, after the attacking unit has finished making its attacks, that unit suffers 1 mortal wound."
      },
      {
        "name": "In the Walls",
